{
  "name": "booking-service-backend",
  "version": "1.0.0",
  "description": "Backend for booking service",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.7.0",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/node": "20.10.5",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "express": "4.18.2",
    "express-validator": "7.0.1",
    "prisma": "5.7.0",
    "typescript": "5.3.3",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0"
  }
}
